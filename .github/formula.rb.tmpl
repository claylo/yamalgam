# typed: true
# frozen_string_literal: true

class Yamalgam < Formula
  desc "A modern, production-ready Rust CLI application."
  homepage "__HOMEPAGE__"
  version "__VERSION__"
  license "Apache-2.0 OR MIT"

  on_macos do
    if Hardware::CPU.arm?
      url "__RELEASE_URL__/yamalgam-#{version}-aarch64-apple-darwin.tar.gz"
      sha256 "__SHA_DARWIN_ARM64__"
    else
      url "__RELEASE_URL__/yamalgam-#{version}-x86_64-apple-darwin.tar.gz"
      sha256 "__SHA_DARWIN_X64__"
    end
  end

  on_linux do
    if Hardware::CPU.arm?
      url "__RELEASE_URL__/yamalgam-#{version}-aarch64-unknown-linux-gnu.tar.gz"
      sha256 "__SHA_LINUX_ARM64__"
    else
      url "__RELEASE_URL__/yamalgam-#{version}-x86_64-unknown-linux-gnu.tar.gz"
      sha256 "__SHA_LINUX_X64__"
    end
  end

  def install
    bin.install "bin/yamalgam"
    man1.install Dir["share/man/man1/*.1"]
    bash_completion.install "share/completions/yamalgam.bash" => "yamalgam"
    zsh_completion.install "share/completions/_yamalgam"
    fish_completion.install "share/completions/yamalgam.fish"
  end

  test do
    assert_match version.to_s, shell_output("\#{bin}/yamalgam --version-only")
  end
end
